generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

enum Role {
  USER
  ADMIN
  
}

model User {
  id         String      @id @default(uuid())
  email      String      @unique
  username   String?
  password   String
  albums     Album[]     @relation("UserCreatedAlbums")
  userAlbums UserAlbum[]
  wishlist   Album[]     @relation("UserWishlist")
  role       Role        @default(USER)
}

model Album {
  id             String        @id @default(uuid())
  title          String
  artist         String
  releaseDate    Int?
  coverUrl       String?
  barCode        String?
  color          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  userId         String
  user           User          @relation("UserCreatedAlbums", fields: [userId], references: [id])
  diskNumber     Int?
  genres         Genre[]       @relation("AlbumGenres")
  styles         Style[]       @relation("AlbumStyles")
  trackCount     Int?
  vinylVariantId String?
  vinylVariant   VinylVariant? @relation(fields: [vinylVariantId], references: [id])
  userAlbums     UserAlbum[]
  formatId       String?
  format         Format?       @relation(fields: [formatId], references: [id])
  wishlistedBy   User[]        @relation("UserWishlist")
}

model UserAlbum {
  id      String @id @default(uuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id])
  albumId String
  album   Album  @relation(fields: [albumId], references: [id])

  price      Float?
  boughtAt   DateTime?
  notes      String?
  copyNumber String?

  conditionId String?
  condition   Condition? @relation(fields: [conditionId], references: [id])

  @@unique([userId, albumId])
}

model VinylVariant {
  id     String  @id @default(uuid())
  nameEN String  @unique
  nameFR String?
  albums Album[]
}

model Genre {
  id     String  @id @default(uuid())
  name   String  @unique
  albums Album[] @relation("AlbumGenres")
  styles Style[]
}

model Style {
  id      String  @id @default(uuid())
  name    String  @unique
  genreId String
  genre   Genre   @relation(fields: [genreId], references: [id])
  albums  Album[] @relation("AlbumStyles")
}

model Condition {
  id         String      @id @default(uuid())
  nameEN     String      @unique
  nameFR     String?
  userAlbums UserAlbum[]
}

model Format {
  id          String  @id @default(uuid())
  name        String  @unique
  speed       String?
  description String?
  albums      Album[]
}
